{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "paths": {
      "@flowmind/shared-types": ["packages/shared-types/src"],
      "@flowmind/shared": ["packages/shared/src"],
      "@flowmind/ai-providers": ["packages/ai-providers/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}

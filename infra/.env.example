# FlowMind AI - Local Docker Compose Environment
# Copy to .env in root or relevant app and adjust. Never commit real secrets.

# Control plane
CONTROL_DATABASE_URL=postgresql://flowmind:flowmind_dev@postgres-control:5432/flowmind_control

# Example client route (seeded into control plane)
# Actual client DB URLs are looked up at runtime via client_routes table.
# For direct access in seeds/worker in compose: 
CLIENT_A_DATABASE_URL=postgresql://client_a:client_a_dev@postgres-client-a:5432/client_a_db

# Redis
REDIS_URL=redis://redis:6379

# Object storage (MinIO local)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_REGION=us-east-1

# Auth
JWT_SECRET=dev-super-secret-change-in-real-env
JWT_EXPIRES_IN=7d

# Dev helper: allow X-Client-Id header when not on a real client subdomain
ALLOW_DEV_CLIENT_HEADER=true

# API / ports
PORT=4000
WEB_PORT=3000

# AI (MVP - stub or real key for the provider you test with; per-client in production)
# OPENAI_API_KEY=sk-...
# Do not enable real AI calls until after timeline + processing is solid.

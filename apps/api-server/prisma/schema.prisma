// FlowMind AI - Control Plane Prisma Schema (MVP)
// ONLY routing, licensing, platform admin, and metadata.
// NO client operational data (sessions, events, SOPs, artifacts) here.
// Per the Hybrid Shared-Application, Client-Isolated Data Architecture.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL supplied via prisma.config.ts (new Prisma 7+ requirement) + process.env.DATABASE_URL
  // See prisma.config.ts and CONTROL_DATABASE_URL mapped in docker-compose.
}

// Client organization / tenant
model Client {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // used for subdomain e.g. "acme" -> acme.flowmind.ai
  status      String   @default("active") // active, suspended, deleted
  plan        String   @default("mvp")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  routes      ClientRoute[]
  licenses    ClientLicense[]

  @@map("clients")
}

// Infrastructure routing for a client (the key isolation pointer)
model ClientRoute {
  id                String   @id @default(uuid())
  clientId          String   @map("client_id")
  dbConnectionRef   String   @map("db_connection_ref") // e.g. "postgresql://.../client_a_db" or secret ref
  s3BucketRef       String   @map("s3_bucket_ref")     // e.g. "client-a-artifacts"
  vectorNamespace   String   @map("vector_namespace")  // for pgvector, e.g. "client_a"
  aiConfigRef       String   @map("ai_config_ref")     // JSON or ref to provider + key/endpoint
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId])
  @@map("client_routes")
}

model ClientLicense {
  id          String    @id @default(uuid())
  clientId    String    @map("client_id")
  status      String    @default("active")
  maxUsers    Int       @default(50) @map("max_users")
  maxWorkstations Int   @default(20) @map("max_workstations")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@map("client_licenses")
}

// Internal FlowMind platform admins (control plane only)
model PlatformAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("platform_admin") // platform_admin, platform_viewer
  status    String   @default("active")
  passwordHash String @map("password_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_admins")
}

// Append-only audit for control plane actions
model PlatformAuditLog {
  id          String   @id @default(uuid())
  actorId     String?  @map("actor_id") // platform admin or system
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("platform_audit_logs")
}

// ============================================================
// CLIENT DATA PLANE MODELS (per-client DB)
// These live ONLY in client-specific databases (e.g. client_a_db).
// Control plane has no knowledge of these tables.
// ============================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("CONTRIBUTOR")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions Session[]

  @@map("users")
}

model CapturePolicy {
  id                 String   @id @default(uuid())
  screenshotsEnabled Boolean  @default(true) @map("screenshots_enabled")
  appBlocklist       Json     @default("[]") @map("app_blocklist")
  windowBlocklist    Json     @default("[]") @map("window_blocklist")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("capture_policies")
}

model Session {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  status             String   @default("CREATED")
  startedAt          DateTime @default(now()) @map("started_at")
  endedAt            DateTime? @map("ended_at")
  sourceAgentVersion String?  @map("source_agent_version")
  createdAt          DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id])
  events    Event[]
  artifacts Artifact[]

  @@map("sessions")
}

model Event {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  sequenceNo  Int      @map("sequence_no")
  eventType   String   @map("event_type")
  timestamp   DateTime
  appName     String?  @map("app_name")
  windowTitle String?  @map("window_title")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  session   Session    @relation(fields: [sessionId], references: [id])
  artifacts Artifact[]

  @@map("events")
}

model Artifact {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  eventId      String?  @map("event_id")
  storageKey   String   @map("storage_key")
  artifactType String   @map("artifact_type")
  hash         String?
  sizeBytes    Int      @map("size_bytes")
  uploadStatus String   @default("pending") @map("upload_status")
  createdAt    DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])
  event   Event?  @relation(fields: [eventId], references: [id])

  @@map("artifacts")
}

// Workflow draft from session events (Timeline Builder output)
model Workflow {
  id               String   @id @default(uuid())
  sourceSessionId  String   @unique @map("source_session_id")
  title            String
  summary          String?
  steps            Json     // [{ stepNo: number, title: string, description: string, eventRefs?: string[] }]
  createdAt        DateTime @default(now()) @map("created_at")

  sopDocuments SopDocument[]

  @@map("workflows")
}

// SOP draft (template-based generator output)
model SopDocument {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  title       String
  status      String   @default("DRAFT") // DRAFT, IN_REVIEW, APPROVED, REJECTED
  content     Json     // { title, purpose, scope, prerequisites, procedure: [...], decisionPoints: [...], exceptions: [...], checklist: [...] }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workflow Workflow @relation(fields: [workflowId], references: [id])

  @@map("sop_documents")
}

